# Telegram Bot (required)
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=your_bot_username
ADMIN_IDS=123456789,987654321
ADMIN_PANEL_PATH=/sys/dc-panel

# Site URL (for FAQ / Warranty links)
SITE_URL=https://your-site.com

# XUI Panel (optional — used as default server if DB is empty)
# Servers can also be added via bot /add_server or site admin panel
XUI_URL=https://your-xui-panel.com:54321
XUI_USERNAME=admin
XUI_PASSWORD=admin
XUI_CERT_PATH=

# Database: sqlite | postgres
DB_TYPE=sqlite

# For SQLite (default)
DB_PATH=bot.db

# For PostgreSQL (used in Docker)
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=xuibot
# DB_USER=xuibot
# DB_PASSWORD=changeme
